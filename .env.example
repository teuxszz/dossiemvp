# Copie este arquivo para ".env.local" e preencha com as credenciais do seu projeto Supabase.
# (.env.local é ignorado pelo git — nunca comite chaves reais.)
#
# Onde achar: Supabase Dashboard > seu projeto > Project Settings > Data API / API Keys
#
# Se você deixar estes valores em branco, o app roda com DADOS DE EXEMPLO (mock)
# automaticamente — útil para testar o layout antes de configurar o banco.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
